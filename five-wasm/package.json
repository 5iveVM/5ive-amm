{
  "name": "five-vm-wasm",
  "version": "0.1.0",
  "description": "WebAssembly bindings for Stacks VM with TypeScript support",
  "main": "wrapper/index.ts",
  "types": "pkg/five_vm_wasm.d.ts",
  "files": [
    "pkg",
    "wrapper"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "build:nodejs": "wasm-pack build --target nodejs --out-dir pkg-node",
    "build:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler",
    "build:all": "npm run build && npm run build:nodejs && npm run build:bundler",
    "dev": "wasm-pack build --dev --target web --out-dir pkg",
    "test": "wasm-pack test --headless --firefox",
    "test:node": "wasm-pack test --node",
    "test:integration": "jest tests/integration.test.ts",
    "test:wasm": "jest tests/wasm_compiler_integration.test.ts",
    "test:partial": "jest tests/partial_execution.test.ts",
    "test:validation": "jest tests/validation.test.ts",
    "test:deployment": "jest tests/deployment.test.ts",
    "test:playground": "jest tests/playground.test.ts",
    "test:ts": "jest tests/*.test.ts",
    "benchmark": "node scripts/benchmark.js",
    "size-analysis": "node scripts/size-analysis.js",
    "wasm-test": "ts-node app/wasm-test-cli.ts",
    "deploy": "ts-node app/deploy-cli.ts",
    "example": "ts-node examples/wasm-integration-example.ts",
    "playground": "ts-node examples/playground-demo.ts",
    "lint": "eslint wrapper/**/*.ts app/**/*.ts",
    "type-check": "tsc --noEmit wrapper/index.ts app/wasm-compiler.ts app/deployment-service.ts"
  },
  "bin": {
    "wasm-test-cli": "./app/wasm-test-cli.ts",
    "stacks-deploy": "./app/deploy-cli.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.8",
    "@solana/wallet-adapter-base": "^0.9.23",
    "@solana/wallet-adapter-react": "^0.15.35",
    "@solana/wallet-adapter-wallets": "^0.19.32",
    "@solana/wallet-adapter-react-ui": "^0.9.34",
    "bs58": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7",
    "@tanstack/react-table": "^8.10.7"
  },
  "keywords": [
    "wasm",
    "webassembly",
    "stacks",
    "vm",
    "blockchain",
    "bytecode",
    "rust",
    "typescript"
  ],
  "author": "Stacks Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stacks/stacks-vm"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}