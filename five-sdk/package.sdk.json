{
  "name": "@five-vm/sdk",
  "version": "1.1.1",
  "description": "Client-agnostic TypeScript SDK for Five VM scripts on Solana",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "five",
    "vm",
    "solana",
    "blockchain",
    "sdk",
    "client-agnostic",
    "wasm",
    "bytecode"
  ],
  "author": "Five VM Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/five-vm/five-cli.git",
    "directory": "src/sdk"
  },
  "bugs": {
    "url": "https://github.com/five-vm/five-cli/issues"
  },
  "homepage": "https://github.com/five-vm/five-cli/tree/main/src/sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "dist/**/*.d.ts.map",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {},
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node examples/basic-usage.js",
    "prepublishOnly": "npm run build"
  }
}