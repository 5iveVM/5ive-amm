{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["es2020"],
    "types": ["node"],
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "src/testing/**/*",
    "src/__tests__/**/*",
    "src/**/__tests__/**/*",
    "src/examples/**/*",
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
