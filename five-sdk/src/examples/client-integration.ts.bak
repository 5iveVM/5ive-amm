/**
 * Five SDK Client Integration Examples
 * 
 * Demonstrates how to use the client-agnostic Five SDK with different Solana client libraries.
 * The Five SDK generates serialized instruction data that can be consumed by any Solana client.
 */

// ==================== Web3.js Integration ====================

/**
 * Example: Using Five SDK with @solana/web3.js
 */
export async function web3jsExample() {
  // Note: These imports would be from actual libraries in a real implementation
  // import { Connection, Transaction, TransactionInstruction, PublicKey, Keypair } from '@solana/web3.js';
  // import { FiveSDK } from '../index.js';
  
  console.log('=== Five SDK with @solana/web3.js ===');
  
  // 1. Compile Five script using client-agnostic SDK
  const scriptSource = `
    script Calculator {
      add(a: u64, b: u64) -> u64 {
        return a + b;
      }
      
      test() -> u64 {
        return add(5, 3);
      }
    }
  `;
  
  // Static method - no client dependencies
  const compilation = await FiveSDK.compile(scriptSource, { debug: true });
  
  if (!compilation.success || !compilation.bytecode) {
    throw new Error('Compilation failed');
  }
  
  // 2. Generate deployment instruction data
  const walletPubkey = 'Fg6PaFpoGXkYsidMpWTK6W2BeZ7FEfcYkg476zPFsLnS'; // Example base58 pubkey
  const deploymentData = await FiveSDK.generateDeployInstruction(
    compilation.bytecode,
    walletPubkey,
    { debug: true }
  );
  
  // 3. Convert to web3.js instruction
  const deployInstruction = toWeb3Instruction(deploymentData.instruction);
  
  // 4. Create transaction and send (pseudo-code)
  // const transaction = new Transaction().add(deployInstruction);
  // const signature = await connection.sendTransaction(transaction, [wallet]);
  
  console.log('✓ Deployment instruction generated for web3.js');
  console.log(`  Script Account: ${deploymentData.scriptAccount}`);
  console.log(`  Estimated Cost: ${deploymentData.estimatedCost} lamports`);
  
  // 5. Generate execution instruction
  const executionData = await FiveSDK.generateExecuteInstruction(
    deploymentData.scriptAccount,
    'test',
    [],
    [],
    { debug: true }
  );
  
  const executeInstruction = toWeb3Instruction(executionData.instruction);
  
  console.log('✓ Execution instruction generated for web3.js');
  console.log(`  Function: test()`);
  console.log(`  Estimated CU: ${executionData.estimatedComputeUnits}`);
  
  return {
    deployInstruction,
    executeInstruction,
    deploymentData,
    executionData
  };
}

/**
 * Helper: Convert SerializedInstruction to web3.js TransactionInstruction
 */
function toWeb3Instruction(serializedInstruction: any): any {
  // In real implementation:
  /*
  return new TransactionInstruction({
    programId: new PublicKey(serializedInstruction.programId),
    keys: serializedInstruction.accounts.map((acc: any) => ({
      pubkey: new PublicKey(acc.pubkey),
      isSigner: acc.isSigner,
      isWritable: acc.isWritable
    })),
    data: Buffer.from(serializedInstruction.data, 'base64')
  });
  */
  
  return {
    programId: serializedInstruction.programId,
    keys: serializedInstruction.accounts,
    data: serializedInstruction.data
  };
}

// ==================== Custom Client Integration ====================

/**
 * Example: Using Five SDK with a custom Solana client
 */
export async function customClientExample() {
  console.log('=== Five SDK with Custom Solana Client ===');
  
  // Custom client interface
  interface CustomSolanaClient {
    sendTransaction(instruction: CustomInstruction): Promise<string>;
    getAccount(pubkey: string): Promise<any>;
  }
  
  interface CustomInstruction {
    program: string;
    accounts: Array<{ key: string; signer: boolean; writable: boolean }>;
    data: Uint8Array;
  }
  
  // Mock custom client
  const customClient: CustomSolanaClient = {
    async sendTransaction(instruction: CustomInstruction): Promise<string> {
      console.log('Custom client sending transaction:', {
        program: instruction.program,
        accounts: instruction.accounts.length,
        dataSize: instruction.data.length
      });
      return 'custom-tx-signature-' + Date.now();
    },
    async getAccount(pubkey: string): Promise<any> {
      return { pubkey, lamports: 1000000, data: new Uint8Array(0) };
    }
  };
  
  // Use Five SDK to generate instruction data
  const executionData = await FiveSDK.generateExecuteInstruction(
    'ScriptAccount11111111111111111111111111111', // Mock script account
    'add',
    [10, 20],
    [],
    { debug: true }
  );
  
  // Convert to custom client format
  const customInstruction: CustomInstruction = {
    program: executionData.instruction.programId,
    accounts: executionData.instruction.accounts.map(acc => ({
      key: acc.pubkey,
      signer: acc.isSigner,
      writable: acc.isWritable
    })),
    data: Buffer.from(executionData.instruction.data, 'base64')
  };
  
  // Send with custom client
  const signature = await customClient.sendTransaction(customInstruction);
  
  console.log('✓ Custom client transaction sent');
  console.log(`  Signature: ${signature}`);
  
  return { signature, executionData };
}

// ==================== Anchor Framework Integration ====================

/**
 * Example: Using Five SDK with Anchor framework
 */
export async function anchorExample() {
  console.log('=== Five SDK with Anchor Framework ===');
  
  // Anchor program interface (mock)
  interface AnchorProgram {
    methods: {
      executeFiveScript(data: Buffer): {
        accounts(accounts: any): {
          rpc(): Promise<string>;
        };
      };
    };
  }
  
  // Mock anchor program
  const anchorProgram: AnchorProgram = {
    methods: {
      executeFiveScript: (data: Buffer) => ({
        accounts: (accounts: any) => ({
          rpc: async () => {
            console.log('Anchor executing Five script:', {
              dataSize: data.length,
              accounts: Object.keys(accounts).length
            });
            return 'anchor-tx-signature-' + Date.now();
          }
        })
      })
    }
  };
  
  // Generate Five execution data
  const executionData = await FiveSDK.generateExecuteInstruction(
    'ScriptAccount11111111111111111111111111111',
    'test',
    [],
    ['Account1111111111111111111111111111111'],
    { debug: true }
  );
  
  // Use with Anchor
  const instructionData = Buffer.from(executionData.instruction.data, 'base64');\n  const accountMap = {\n    script: executionData.scriptAccount,\n    user: executionData.instruction.accounts[1]?.pubkey || 'User1111111111111111111111111111111'\n  };\n  \n  const signature = await anchorProgram.methods\n    .executeFiveScript(instructionData)\n    .accounts(accountMap)\n    .rpc();\n  \n  console.log('✓ Anchor framework execution completed');\n  console.log(`  Signature: ${signature}`);\n  \n  return { signature, executionData };\n}\n\n// ==================== Mobile/React Native Integration ====================\n\n/**\n * Example: Using Five SDK in mobile/React Native environment\n */\nexport async function mobileExample() {\n  console.log('=== Five SDK in Mobile Environment ===');\n  \n  // Mobile wallet interface (simplified)\n  interface MobileWallet {\n    publicKey: string;\n    signTransaction(transaction: MobileTransaction): Promise<string>;\n  }\n  \n  interface MobileTransaction {\n    instructions: Array<{\n      programId: string;\n      accounts: Array<{ pubkey: string; isSigner: boolean; isWritable: boolean }>;\n      data: string; // base64\n    }>;\n  }\n  \n  // Mock mobile wallet\n  const mobileWallet: MobileWallet = {\n    publicKey: 'MobileWallet1111111111111111111111111111',\n    async signTransaction(transaction: MobileTransaction): Promise<string> {\n      console.log('Mobile wallet signing transaction:', {\n        instructions: transaction.instructions.length\n      });\n      return 'mobile-signature-' + Date.now();\n    }\n  };\n  \n  // Compile script for mobile execution\n  const mobileScript = `\n    script MobileScript {\n      greet(name: string) -> string {\n        return \"Hello \" + name + \" from mobile!\";\n      }\n    }\n  `;\n  \n  const compilation = await FiveSDK.compile(mobileScript, { debug: true });\n  \n  if (!compilation.success || !compilation.bytecode) {\n    throw new Error('Mobile script compilation failed');\n  }\n  \n  // Generate deployment for mobile\n  const deploymentData = await FiveSDK.generateDeployInstruction(\n    compilation.bytecode,\n    mobileWallet.publicKey,\n    { debug: true }\n  );\n  \n  // Create mobile transaction\n  const mobileTransaction: MobileTransaction = {\n    instructions: [deploymentData.instruction]\n  };\n  \n  const signature = await mobileWallet.signTransaction(mobileTransaction);\n  \n  console.log('✓ Mobile deployment completed');\n  console.log(`  Script Account: ${deploymentData.scriptAccount}`);\n  console.log(`  Signature: ${signature}`);\n  \n  return { signature, deploymentData };\n}\n\n// ==================== Browser-Only Integration ====================\n\n/**\n * Example: Using Five SDK in browser without Node.js dependencies\n */\nexport async function browserExample() {\n  console.log('=== Five SDK in Browser Environment ===');\n  \n  // Browser-based Solana client (simplified)\n  interface BrowserSolanaClient {\n    sendTransaction(instruction: any): Promise<{ signature: string; slot: number }>;\n    confirmTransaction(signature: string): Promise<boolean>;\n  }\n  \n  const browserClient: BrowserSolanaClient = {\n    async sendTransaction(instruction: any): Promise<{ signature: string; slot: number }> {\n      // Simulate browser transaction\n      const signature = 'browser-' + Math.random().toString(36).substring(2);\n      const slot = Math.floor(Math.random() * 1000000);\n      \n      console.log('Browser client sending transaction:', {\n        program: instruction.programId,\n        signature,\n        slot\n      });\n      \n      return { signature, slot };\n    },\n    async confirmTransaction(signature: string): Promise<boolean> {\n      console.log(`Browser confirming transaction: ${signature}`);\n      return true;\n    }\n  };\n  \n  // Simple browser script\n  const browserScript = 'script BrowserTest { test() -> u64 { return 42; } }';\n  \n  // Compile in browser\n  const compilation = await FiveSDK.compile(browserScript, { debug: true });\n  \n  if (!compilation.success || !compilation.bytecode) {\n    throw new Error('Browser compilation failed');\n  }\n  \n  // Generate execution instruction\n  const executionData = await FiveSDK.generateExecuteInstruction(\n    'BrowserScript111111111111111111111111111',\n    'test',\n    [],\n    [],\n    { debug: true }\n  );\n  \n  // Send via browser client\n  const result = await browserClient.sendTransaction(executionData.instruction);\n  const confirmed = await browserClient.confirmTransaction(result.signature);\n  \n  console.log('✓ Browser execution completed');\n  console.log(`  Signature: ${result.signature}`);\n  console.log(`  Slot: ${result.slot}`);\n  console.log(`  Confirmed: ${confirmed}`);\n  \n  return { result, confirmed, executionData };\n}\n\n// ==================== Complete Workflow Example ====================\n\n/**\n * Example: Complete workflow from compilation to execution\n */\nexport async function completeWorkflowExample() {\n  console.log('=== Complete Five SDK Workflow ===');\n  \n  try {\n    // 1. Compile script\n    const script = `\n      script CompleteExample {\n        calculate(x: u64, y: u64) -> u64 {\n          return x * y + 10;\n        }\n        \n        test() -> u64 {\n          return calculate(5, 6); // Should return 40\n        }\n      }\n    `;\n    \n    console.log('Step 1: Compiling script...');\n    const compilation = await FiveSDK.compile(script, { debug: true });\n    \n    if (!compilation.success || !compilation.bytecode) {\n      throw new Error('Compilation failed');\n    }\n    \n    console.log(`✓ Compilation successful: ${compilation.bytecode.length} bytes`);\n    \n    // 2. Generate deployment\n    console.log('Step 2: Generating deployment instruction...');\n    const deployment = await FiveSDK.generateDeployInstruction(\n      compilation.bytecode,\n      'Deployer1111111111111111111111111111111',\n      { debug: true }\n    );\n    \n    console.log(`✓ Deployment instruction generated`);\n    console.log(`  Script Account: ${deployment.scriptAccount}`);\n    console.log(`  Cost: ${deployment.estimatedCost} lamports`);\n    \n    // 3. Generate execution instructions\n    console.log('Step 3: Generating execution instructions...');\n    \n    const testExecution = await FiveSDK.generateExecuteInstruction(\n      deployment.scriptAccount,\n      'test',\n      [],\n      [],\n      { debug: true }\n    );\n    \n    const calculateExecution = await FiveSDK.generateExecuteInstruction(\n      deployment.scriptAccount,\n      'calculate',\n      [7, 8],\n      [],\n      { debug: true }\n    );\n    \n    console.log('✓ Execution instructions generated');\n    console.log(`  Test function: ${testExecution.estimatedComputeUnits} CU`);\n    console.log(`  Calculate function: ${calculateExecution.estimatedComputeUnits} CU`);\n    \n    // 4. Summary\n    console.log('Step 4: Workflow summary');\n    console.log('✓ Five SDK successfully generated all instruction data');\n    console.log('✓ Instructions ready for any Solana client library');\n    console.log('✓ Client-agnostic architecture working correctly');\n    \n    return {\n      compilation,\n      deployment,\n      executions: {\n        test: testExecution,\n        calculate: calculateExecution\n      }\n    };\n    \n  } catch (error) {\n    console.error('❌ Workflow failed:', error);\n    throw error;\n  }\n}\n\n// ==================== Run All Examples ====================\n\n/**\n * Run all integration examples\n */\nexport async function runAllExamples() {\n  console.log('Five SDK Client Integration Examples');\n  console.log('='.repeat(50));\n  \n  try {\n    // Note: In real implementation, these would use actual libraries\n    console.log('Note: These examples use mock implementations for demonstration');\n    console.log('In production, import actual Solana client libraries');\n    console.log('');\n    \n    await web3jsExample();\n    console.log('');\n    \n    await customClientExample();\n    console.log('');\n    \n    await anchorExample();\n    console.log('');\n    \n    await mobileExample();\n    console.log('');\n    \n    await browserExample();\n    console.log('');\n    \n    await completeWorkflowExample();\n    console.log('');\n    \n    console.log('✅ All integration examples completed successfully!');\n    console.log('');\n    console.log('Key Benefits Demonstrated:');\n    console.log('• Client-agnostic design works with any Solana library');\n    console.log('• Pure serialization eliminates client dependencies');\n    console.log('• Same Five SDK works in Node.js, browser, and mobile');\n    console.log('• ABI-driven parameter encoding simplifies usage');\n    console.log('• Flexible architecture supports custom integrations');\n    \n  } catch (error) {\n    console.error('❌ Integration examples failed:', error);\n  }\n}\n\n// Export for individual testing\nexport {\n  toWeb3Instruction\n};\n\n// Run examples if executed directly\nif (typeof window === 'undefined' && import.meta.url === `file://${process.argv[1]}`) {\n  runAllExamples().catch(console.error);\n}\n\n// Mock import for FiveSDK (in real usage, this would be actual import)\nconst FiveSDK = {\n  async compile(source: string, options: any) {\n    return {\n      success: true,\n      bytecode: new Uint8Array([1, 2, 3, 4, 5]), // Mock bytecode\n      metadata: {\n        functions: [\n          { name: 'test', parameters: [] },\n          { name: 'add', parameters: [{ name: 'a', type: 'u64' }, { name: 'b', type: 'u64' }] }\n        ]\n      }\n    };\n  },\n  \n  async generateDeployInstruction(bytecode: Uint8Array, deployer: string, options: any) {\n    return {\n      instruction: {\n        programId: '7wVkyXsUiRcZtAHGZcXbTPCXnE7DBP6juN35H6FEUUZo',\n        accounts: [\n          { pubkey: 'ScriptPDA11111111111111111111111111111', isSigner: false, isWritable: true },\n          { pubkey: deployer, isSigner: true, isWritable: true }\n        ],\n        data: 'AQIDBAUGBwg=' // Mock base64 data\n      },\n      scriptAccount: 'ScriptPDA11111111111111111111111111111',\n      requiredSigners: [deployer],\n      estimatedCost: 5000000,\n      bytecodeSize: bytecode.length\n    };\n  },\n  \n  async generateExecuteInstruction(scriptAccount: string, functionName: string, params: any[], accounts: string[], options: any) {\n    return {\n      instruction: {\n        programId: '7wVkyXsUiRcZtAHGZcXbTPCXnE7DBP6juN35H6FEUUZo',\n        accounts: [\n          { pubkey: scriptAccount, isSigner: false, isWritable: false },\n          ...accounts.map(acc => ({ pubkey: acc, isSigner: false, isWritable: true }))\n        ],\n        data: 'AgAAAQIDBA==' // Mock base64 execution data\n      },\n      scriptAccount,\n      parameters: {\n        function: functionName,\n        data: new Uint8Array([2, 0, 0, 1, 2, 3, 4]),\n        count: params.length\n      },\n      requiredSigners: [],\n      estimatedComputeUnits: 10000\n    };\n  }\n};\n"