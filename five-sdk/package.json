{
  "name": "five-sdk",
  "version": "1.1.2",
  "description": "Client-agnostic TypeScript SDK for Five VM scripts on Solana",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "five",
    "vm",
    "solana",
    "sdk",
    "wasm"
  ],
  "author": "Five VM Team",
  "license": "MIT",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "mkdir -p dist/assets/vm && cp src/assets/wasm/* dist/assets/vm/",
    "test": "node examples/basic-usage.js",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.90.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.16",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.3"
  }
}
