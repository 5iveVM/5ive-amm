{
  "name": "five-language-support",
  "displayName": "5ive Language Support",
  "description": "Native LSP-powered support for the 5ive DSL.",
  "version": "0.1.0",
  "publisher": "five-placeholder",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:five",
    "onCommand:five.restartLanguageServer",
    "onCommand:five.showLanguageServerStatus"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "five",
        "aliases": [
          "5ive",
          "five"
        ],
        "extensions": [
          ".v",
          ".five"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "five",
        "scopeName": "source.five",
        "path": "./syntaxes/five.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "five.restartLanguageServer",
        "title": "5ive: Restart Language Server"
      },
      {
        "command": "five.showLanguageServerStatus",
        "title": "5ive: Show Language Server Status"
      }
    ],
    "configuration": {
      "title": "5ive",
      "properties": {
        "five.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Absolute path override for the five-lsp native binary."
        },
        "five.languageServer.trace": {
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "markdownDescription": "Trace level for LSP protocol logging."
        }
      }
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p ./tsconfig.json",
    "lint": "tsc -p ./tsconfig.json --noEmit",
    "package:vsix": "npm run build && vsce package --no-dependencies",
    "package:target": "npm run build && node ./scripts/package-target.mjs",
    "test:smoke": "node ./scripts/smoke-check.mjs"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.27.0",
    "rimraf": "^5.0.10",
    "typescript": "^5.8.3"
  }
}
