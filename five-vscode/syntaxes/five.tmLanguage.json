{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "5ive DSL",
  "scopeName": "source.five",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.five",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.five",
          "match": "\\b(instruction|function|pub|let|mut|if|else|match|return|require|emit|account|event|interface|import|use|for|while|break|continue)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.five",
          "match": "\\b(u8|u16|u32|u64|u128|i8|i16|i32|i64|bool|string|pubkey|lamports|Option|Result|Account)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.five",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.five",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  }
}
